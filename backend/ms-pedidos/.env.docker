PORT=3001

# Database Configuration (Docker network service name)
DB_HOST=db-pedidos
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=0910
DB_NAME=pedidos

# JWT Authorization Public Key path inside the container
JWT_PUBLIC_KEY_PATH=certs/public.pem

# AWS / LocalStack Configuration
# Set STORAGE_TYPE to 's3' in production, or 'local' for local file storage
STORAGE_TYPE=local
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
# When running inside Docker, use host.docker.internal or localstack service name
AWS_ENDPOINT_URL=http://host.docker.internal:4566
AWS_S3_BUCKET_NAME=polloscarmesi-delivery-evidence
DYNAMODB_EVENTS_TABLE=polloscarmesi-events
DYNAMODB_GPS_TABLE=polloscarmesi-gps

# Microservice integrations (Docker network service names or host.docker.internal)
AUTH_SERVICE_URL=http://host.docker.internal:8081/api
MS1_REST_INTERNAL_URL=http://host.docker.internal:8082/api
MS3_REST_INTERNAL_URL=http://host.docker.internal:3002/api

# Gemini API Key (keep this template or inject at runtime)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
